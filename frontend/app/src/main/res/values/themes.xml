<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TakeTwo_PartB" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/casino_gold</item>
        <item name="colorPrimaryVariant">@color/casino_gold_dark</item>
        <item name="colorOnPrimary">@color/casino_bg_dark</item>
        <item name="colorSecondary">@color/casino_accent</item>
        <item name="colorSecondaryVariant">@color/casino_accent_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/casino_bg_dark</item>
        <item name="android:windowBackground">@color/casino_bg_dark</item>
        <item name="android:textColorPrimary">@color/casino_text_primary</item>
        <item name="android:textColorSecondary">@color/casino_text_secondary</item>
    </style>


    <style name="CasinoButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/casino_gold</item>
        <item name="android:textColor">@color/casino_bg_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="textAllCaps">false</item>
    </style>


    <style name="CasinoButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/casino_gold</item>
        <item name="android:textColor">@color/casino_gold</item>
        <item name="cornerRadius">12dp</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="CasinoCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/casino_bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="CasinoAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnSurface">@color/casino_text_primary</item>
        <item name="backgroundTint">@color/casino_bg_card</item>
    </style>
</resources>
