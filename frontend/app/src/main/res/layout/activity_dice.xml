<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/casino_bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_card_casino"
                android:src="@drawable/baseline_arrow_back_24"
                android:padding="8dp"
                app:tint="@color/casino_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎲 Dice Game"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/casino_text_primary"
                android:gravity="center"
                android:layout_marginEnd="40dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_casino"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:letterSpacing="0.2"
                android:text="ROLL THE DICE"
                android:textColor="@color/casino_text_muted"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvDice1"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="⚀"
                    android:textSize="52sp"
                    android:gravity="center"
                    android:background="@drawable/bg_dice_cell"
                    android:padding="12dp"
                    android:layout_margin="8dp" />

                <TextView
                    android:id="@+id/tvDice2"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="⚀"
                    android:textSize="52sp"
                    android:gravity="center"
                    android:background="@drawable/bg_dice_cell"
                    android:padding="12dp"
                    android:layout_margin="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSelectedSide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rolling..."
                android:textColor="@color/casino_text_muted"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_casino"
            android:padding="20dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLACE YOUR BET"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etBetAmount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Bet amount"
                android:textColor="@color/casino_text_primary"
                android:textColorHint="@color/casino_text_muted"
                android:background="@drawable/bg_input_casino"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="numberDecimal"
                android:textSize="16sp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnRoll"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🎲  ROLL DICE"
                android:textColor="@color/casino_bg_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/bg_button_gold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_result_panel"
            android:padding="20dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESULT"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:letterSpacing="0.2"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Winnings"
                        android:textSize="11sp"
                        android:textColor="@color/casino_text_muted" />

                    <TextView
                        android:id="@+id/tvWinnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/casino_text_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profit"
                        android:textSize="11sp"
                        android:textColor="@color/casino_text_muted" />

                    <TextView
                        android:id="@+id/tvProfit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/casino_text_primary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Multiplier"
                        android:textSize="11sp"
                        android:textColor="@color/casino_text_muted" />

                    <TextView
                        android:id="@+id/tvMultiplier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/casino_accent_light" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jackpot"
                        android:textSize="11sp"
                        android:textColor="@color/casino_text_muted" />

                    <TextView
                        android:id="@+id/tvJackpot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NO"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/casino_red" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/casino_border"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Balance"
                    android:textSize="13sp"
                    android:textColor="@color/casino_text_secondary" />

                <TextView
                    android:id="@+id/tvBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/casino_gold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>