<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/casino_bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_card_casino"
                android:src="@drawable/baseline_arrow_back_24"
                android:padding="8dp"
                app:tint="@color/casino_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🐔 Chicken Road"
                android:textColor="@color/casino_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ROAD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_casino"
            android:padding="20dp"
            android:layout_marginTop="16dp"
            android:gravity="start">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHICKEN ROAD"
                android:textSize="12sp"
                android:textColor="@color/casino_text_muted"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/roadContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvOutcome2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="start"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvProgress2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step: 0"
                android:textSize="14sp"
                android:textColor="@color/casino_text_muted"
                android:gravity="start"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvCurrentMultiplier2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Multiplier: 1.0x"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/casino_accent_light"
                android:gravity="start"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- DECIDE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_casino"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:gravity="start">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DECIDE NEXT"
                android:textSize="12sp"
                android:textColor="@color/casino_text_muted"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnChooseMove2"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="MOVE"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_gold"/>

                <Button
                    android:id="@+id/btnChooseStop2"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="CASHOUT"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_outlined"/>
            </LinearLayout>
        </LinearLayout>

        <!-- BET -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_casino"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:gravity="start">

            <EditText
                android:id="@+id/etBetAmount2"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Bet amount"
                android:textColor="@color/casino_text_primary"
                android:textColorHint="@color/casino_text_muted"
                android:inputType="numberDecimal"
                android:textSize="16sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <Button
                android:id="@+id/btnFlip2"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="PLAY ROUND"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <Button
                android:id="@+id/btnreset"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="RESET GAME"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- RESULT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_result_panel"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:gravity="start">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESULT"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"/>

            <!-- ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvWinnings2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Winnings: —"
                    android:textSize="16sp"
                    android:textColor="@color/casino_text_muted"/>

                <TextView
                    android:id="@+id/tvProfit2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Profit: —"
                    android:textSize="16sp"
                    android:textColor="@color/casino_text_muted"/>
            </LinearLayout>

            <!-- ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvJackpot2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jackpot: NO"
                    android:textSize="16sp"
                    android:textColor="@color/casino_text_muted"/>

                <TextView
                    android:id="@+id/tvBalance2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Balance: —"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/casino_text_muted"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>