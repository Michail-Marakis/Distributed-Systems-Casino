<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/casino_bg_dark"
    android:gravity="center"
    android:padding="32dp">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎰"
        android:textSize="72sp"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Casino"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@color/casino_gold"
        android:layout_marginBottom="30dp"
        android:letterSpacing="0.3"
        android:gravity="center" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_casino"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textSize="13sp"
            android:textColor="@color/casino_text_muted"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your Player ID"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/casino_text_primary"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etSplashPlayerId"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Player ID"
            android:textColor="@color/casino_text_primary"
            android:textColorHint="@color/casino_text_muted"
            android:background="@drawable/bg_input_casino"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnSplashEnter"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ENTER"
            android:textColor="@color/casino_bg_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/bg_button_gold"
            android:letterSpacing="0.08" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutBalanceCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_casino"
        android:padding="24dp"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENT BALANCE"
            android:textSize="11sp"
            android:textColor="@color/casino_text_muted"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="€"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvSplashBalance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.00"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/casino_gold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvSplashUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="@color/casino_text_secondary"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnSplashPlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ENTER CASINO"
            android:textColor="@color/casino_bg_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/bg_button_gold"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSplashStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="@color/casino_text_muted"
        android:gravity="center"
        android:layout_marginTop="16dp" />

</LinearLayout>