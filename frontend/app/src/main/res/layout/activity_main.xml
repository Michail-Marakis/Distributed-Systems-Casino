<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/casino_bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/casino_bg_surface"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="30sp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CASINO"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/casino_gold"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card_casino"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="€ "
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvHeaderBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/casino_gold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_casino"
                android:padding="20dp"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Search"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etPlayerId"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Player ID"
                    android:textColor="@color/casino_text_primary"
                    android:textColorHint="@color/casino_text_muted"
                    android:background="@drawable/bg_input_casino"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etSearchName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Search by game name"
                    android:textColor="@color/casino_text_primary"
                    android:textColorHint="@color/casino_text_muted"
                    android:background="@drawable/bg_input_casino"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etProviderName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Search by provider"
                    android:textColor="@color/casino_text_primary"
                    android:textColorHint="@color/casino_text_muted"
                    android:background="@drawable/bg_input_casino"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="text"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_casino"
                android:padding="20dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FILTERS"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="Risk"
                        android:textSize="13sp"
                        android:textColor="@color/casino_text_secondary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <CheckBox
                            android:id="@+id/cbLow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Low"
                            android:textColor="@color/casino_green"
                            android:buttonTint="@color/casino_green"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:singleLine="true" />

                        <CheckBox
                            android:id="@+id/cbMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medium"
                            android:textColor="@color/casino_gold"
                            android:buttonTint="@color/casino_gold"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:layout_marginStart="12dp" />

                        <CheckBox
                            android:id="@+id/cbHigh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High"
                            android:textColor="@color/casino_red"
                            android:buttonTint="@color/casino_red"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="Bet"
                        android:textSize="13sp"
                        android:textColor="@color/casino_text_secondary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <CheckBox
                            android:id="@+id/cbDollar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$"
                            android:textColor="@color/casino_text_primary"
                            android:buttonTint="@color/casino_accent_light"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:singleLine="true" />

                        <CheckBox
                            android:id="@+id/cbDollar2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$$"
                            android:textColor="@color/casino_text_primary"
                            android:buttonTint="@color/casino_accent_light"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:layout_marginStart="20dp" />

                        <CheckBox
                            android:id="@+id/cbDollar3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$$$"
                            android:textColor="@color/casino_text_primary"
                            android:buttonTint="@color/casino_accent_light"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:layout_marginStart="20dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnSearch"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="SEARCH"
                        android:textColor="@color/casino_bg_dark"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:background="@drawable/bg_button_gold" />

                    <Button
                        android:id="@+id/btnAddBalance"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="ADD BALANCE"
                        android:textColor="@color/casino_bg_dark"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:background="@drawable/bg_button_gold"
                        android:layout_marginStart="10dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_casino"
                android:padding="20dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="GAMES"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:textAllCaps="true"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready"
                        android:textSize="13sp"
                        android:textColor="@color/white" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerGames"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>